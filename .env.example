# Orion environment configuration
# Copy this file to .env and replace placeholder values before running the app.

# LLM Configuration
LLM_PROVIDER=vertexai
# Default model for the selected provider.
LLM_MODEL=gemini-2.5-flash
# Required when LLM_PROVIDER=gemini.
GOOGLE_API_KEY=your_google_api_key_here
# Optional for Vertex AI-backed Gemini usage.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false

# Optional provider keys. Set these only if you switch providers.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# LangSmith Observability
# Enable automatic LangSmith tracing for Orion agent runs.
LANGCHAIN_TRACING_V2=true
# Required LangSmith API key for trace collection.
LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LangSmith project name used to group Orion traces.
LANGCHAIN_PROJECT=orion

# App Configuration
# Relative path to the CSV dataset used by Orion.
DATA_PATH=data/sales_data.csv
# Cloud Run and local server port.
PORT=8080
